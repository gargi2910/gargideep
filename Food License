// ---- HELPERS ----
const today = new Date();
function daysLeft(expiryStr) {
  if(!expiryStr) return 9999;
  const [d,m,y] = expiryStr.split('-').map(Number);
  const exp = new Date(y, m-1, d);
  return Math.round((exp - today) / 86400000);
}
function statusOf(expiryStr) {
  const d = daysLeft(expiryStr);
  if(d < 0) return 'expired';
  if(d <= 30) return 'expiring';
  return 'active';
}
function badgeHtml(s) {
  const cls = {active:'badge-active',expiring:'badge-expiring',expired:'badge-expired'}[s]||'badge-active';
  return `<span class="badge ${cls}">${s}</span>`;
}
function daysHtml(n) {
  if(n === 9999) return '<span class="days-left ok">—</span>';
  if(n < 0) return `<span class="days-left danger">${Math.abs(n)}d over</span>`;
  if(n <= 30) return `<span class="days-left warn">${n}d left</span>`;
  return `<span class="days-left ok">${n}d</span>`;
}
function shortType(t) {
  return t.replace(/ LICENCE$/i,'').replace('/JALPAN GRAH/EATING HOUSE/i','').replace(' (50 BED)','').replace(' UPTO 50 BED','').replace(' (20 BED)','').replace(' UPTO 20 BED','').replace(' ABOVE 20 BED','');
}
function truncate(s,n) { return s && s.length > n ? s.slice(0,n)+'…' : s; }

// ---- LIVE DATA ----
let liveData = RAW_DATA.map(r => ({...r, status: statusOf(r.expiry), daysLeft: daysLeft(r.expiry)}));

// ---- NOTIFICATIONS (auto-generated from real data) ----
let notifications = [];
liveData.filter(r=>r.status==='expired').forEach(r => {
  notifications.push({id:r.id+'exp', type:'r', title:'Licence Expired', msg:`${r.client} (${r.licNo}) expired ${Math.abs(r.daysLeft)}d ago — ${r.ward}`, time:'Automated', unread:true});
});
liveData.filter(r=>r.status==='expiring' && r.daysLeft<=7).forEach(r => {
  notifications.push({id:r.id+'urg', type:'y', title:`Expiring in ${r.daysLeft} day(s)`, msg:`${r.client} (${r.licNo}) — ${r.business||r.ward}`, time:'Automated', unread:true});
});
liveData.filter(r=>r.status==='expiring' && r.daysLeft>7).forEach(r => {
  notifications.push({id:r.id+'rem', type:'y', title:'30-Day Reminder Due', msg:`${r.client} (${r.licNo}) expiry: ${r.expiry}`, time:'Scheduled', unread:false});
});

// ---- PAGINATION state ----
let allPage = 1, allFilter = 'all', allSearch = '';
const PAGE_SIZE = 20;

// ---- RENDER DASH TABLE ----
function renderDash(filter='all') {
  const tbody = document.getElementById('dash-tbody');
  let list = filter==='all' ? liveData : liveData.filter(r=>r.status===filter);
  list = list.slice().sort((a,b)=>a.daysLeft-b.daysLeft).slice(0,15);
  tbody.innerHTML = list.map(r=>`
    <tr onclick="viewDetail(${r.id})">
      <td><div class="td-name">${truncate(r.client,22)}</div><div class="td-sub">${r.ward}</div></td>
      <td style="font-family:var(--font-mono);font-size:11px;color:var(--text3)">${r.licNo}</td>
      <td style="font-size:11px;color:var(--text2)">${truncate(shortType(r.type),25)}</td>
      <td style="font-family:var(--font-mono);font-size:11px">${r.expiry}</td>
      <td>${daysHtml(r.daysLeft)}</td>
      <td>${badgeHtml(r.status)}</td>
      <td><button class="action-btn" onclick="event.stopPropagation();sendReminder(r=${r.id})">📨</button></td>
    </tr>`).join('');
}

// ---- RENDER ALL TABLE with pagination ----
function getFilteredAll() {
  let list = allFilter==='all' ? liveData : liveData.filter(r=>r.status===allFilter);
  if(allSearch) {
    const q = allSearch.toLowerCase();
    list = list.filter(r=>
      r.client.toLowerCase().includes(q)||
      r.licNo.toLowerCase().includes(q)||
      (r.business||'').toLowerCase().includes(q)||
      r.ward.toLowerCase().includes(q)||
      r.type.toLowerCase().includes(q)
    );
  }
  return list.sort((a,b)=>a.daysLeft-b.daysLeft);
}
function renderAll() {
  const list = getFilteredAll();
  const total = list.length;
  const pages = Math.ceil(total/PAGE_SIZE);
  if(allPage > pages) allPage = 1;
  const slice = list.slice((allPage-1)*PAGE_SIZE, allPage*PAGE_SIZE);
  document.getElementById('lic-count').textContent = total + ' records';
  document.getElementById('all-tbody').innerHTML = slice.map(r=>`
    <tr onclick="viewDetail(${r.id})">
      <td><div class="td-name">${truncate(r.client,20)}</div></td>
      <td style="font-size:11px;color:var(--text2)">${truncate(r.business||'—',20)}</td>
      <td style="font-size:11px;color:var(--text2)">${r.ward}</td>
      <td style="font-size:11px">${truncate(shortType(r.type),22)}</td>
      <td style="font-family:var(--font-mono);font-size:10px;color:var(--text3)">${r.licNo}</td>
      <td style="font-size:11px;color:var(--text2)">${r.regFor||'—'}</td>
      <td style="font-size:11px;color:var(--text2)">${r.validFor||'—'}</td>
      <td>${badgeHtml(r.status)}</td>
      <td>${daysHtml(r.daysLeft)}</td>
      <td style="display:flex;gap:5px"><button class="action-btn" onclick="event.stopPropagation();sendReminderById(${r.id})">📨</button></td>
    </tr>`).join('');
  // Pagination
  const pg = document.getElementById('all-pagination');
  if(pages<=1){pg.innerHTML='';return;}
  let btns = `<span class="page-info">Page ${allPage} of ${pages} (${total} records)</span>`;
  if(allPage>1) btns+=`<button class="page-btn" onclick="gotoPage(${allPage-1})">‹ Prev</button>`;
  const start = Math.max(1,allPage-2), end = Math.min(pages,allPage+2);
  for(let i=start;i<=end;i++) btns+=`<button class="page-btn${i===allPage?' active':''}" onclick="gotoPage(${i})">${i}</button>`;
  if(allPage<pages) btns+=`<button class="page-btn" onclick="gotoPage(${allPage+1})">Next ›</button>`;
  pg.innerHTML = btns;
}
function gotoPage(p){allPage=p;renderAll();}
function filterAll(f,el){
  allFilter=f;allPage=1;
  document.querySelectorAll('.tabs .tab').forEach(t=>t.classList.remove('active'));
  if(el)el.classList.add('active');
  renderAll();
}

// ---- EXPIRING TABLE ----
function renderExpiring(){
  const list = liveData.filter(r=>r.status==='expiring').sort((a,b)=>a.daysLeft-b.daysLeft);
  document.getElementById('expiring-tbody').innerHTML = list.map(r=>`
    <tr onclick="viewDetail(${r.id})">
      <td><div class="td-name">${truncate(r.client,22)}</div></td>
      <td style="font-size:11px">${truncate(r.business||'—',22)}</td>
      <td style="font-size:11px;color:var(--text2)">${r.ward}</td>
      <td style="font-family:var(--font-mono);font-size:10px;color:var(--text3)">${r.licNo}</td>
      <td style="font-family:var(--font-mono);font-size:11px">${r.expiry}</td>
      <td>${daysHtml(r.daysLeft)}</td>
      <td style="font-family:var(--font-mono);font-size:11px">₹${r.feePaid||'—'}</td>
      <td><button class="action-btn" onclick="event.stopPropagation();sendReminderById(${r.id})">📨 Remind</button></td>
    </tr>`).join('');
}

// ---- EXPIRED TABLE ----
function renderExpired(){
  const list = liveData.filter(r=>r.status==='expired').sort((a,b)=>a.daysLeft-b.daysLeft);
  const noEl = document.getElementById('no-expired');
  if(list.length===0){noEl.style.display='block';return;}
  noEl.style.display='none';
  document.getElementById('expired-tbody').innerHTML = list.map(r=>`
    <tr onclick="viewDetail(${r.id})">
      <td><div class="td-name">${truncate(r.client,22)}</div></td>
      <td style="font-size:11px">${truncate(r.business||'—',22)}</td>
      <td style="font-size:11px;color:var(--text2)">${r.ward}</td>
      <td style="font-family:var(--font-mono);font-size:10px;color:var(--text3)">${r.licNo}</td>
      <td style="color:var(--red);font-family:var(--font-mono);font-size:11px">${r.expiry}</td>
      <td><span class="days-left danger">${Math.abs(r.daysLeft)}d overdue</span></td>
      <td><button class="action-btn" onclick="event.stopPropagation();sendReminderById(${r.id})">🔄 Renew Notice</button></td>
    </tr>`).join('');
}

// ---- NOTIFICATIONS ----
function renderNotif(id) {
  const el = document.getElementById(id);
  if(!el) return;
  el.innerHTML = notifications.map(n=>`
    <div class="notif-item ${n.unread?'unread':''}" onclick="markRead('${n.id}')">
      <div class="ndot ${n.type}"></div>
      <div class="notif-content">
        <div class="notif-title">${n.title}</div>
        <div class="notif-msg">${n.msg}</div>
        <div class="notif-time">${n.time}</div>
      </div>
      ${n.unread?'<div class="unread-dot"></div>':''}
    </div>`).join('');
}
function markRead(id){ const n=notifications.find(x=>x.id===id); if(n)n.unread=false; renderNotif('notif-list');renderNotif('full-notif-list'); }
function markAllRead(){ notifications.forEach(n=>n.unread=false); renderNotif('notif-list');renderNotif('full-notif-list'); showToast('All notifications marked read.','success'); }

// ---- DETAIL VIEW ----
function viewDetail(id) {
  const r = liveData.find(x=>x.id===id);
  if(!r) return;
  document.getElementById('detail-title').textContent = r.client;
  document.getElementById('detail-sub').innerHTML = `${badgeHtml(r.status)} &nbsp;${r.licNo} — ${r.ward}`;
  document.getElementById('detail-body').innerHTML = `
    <div class="detail-item"><div class="detail-key">Father/Husband Name</div><div class="detail-val">${r.fatherName||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Trade Name</div><div class="detail-val">${r.business||'—'}</div></div>
    <div class="detail-item detail-full"><div class="detail-key">Address</div><div class="detail-val">${r.address||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Licence Type</div><div class="detail-val">${r.type}</div></div>
    <div class="detail-item"><div class="detail-key">Licence Mode</div><div class="detail-val">${r.mode||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Registration Validity</div><div class="detail-val">${r.regFor||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Payment Validity</div><div class="detail-val">${r.validFor||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Expiry Date</div><div class="detail-val" style="color:${r.daysLeft<0?'var(--red)':r.daysLeft<=30?'var(--yellow)':'var(--green)'}">${r.expiry} (${daysHtml(r.daysLeft)})</div></div>
    <div class="detail-item"><div class="detail-key">Acknowledgement Date</div><div class="detail-val">${r.ackDate||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Date of Signing</div><div class="detail-val">${r.signingDate||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Licence Amount (Yearly)</div><div class="detail-val">₹${r.amount||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Fee Paid</div><div class="detail-val">₹${r.feePaid||'—'}</div></div>
    <div class="detail-item"><div class="detail-key">Payment Date</div><div class="detail-val">${r.paymentDate||'—'}</div></div>
    <div class="detail-item detail-full"><div class="detail-key">Application Status</div><div class="detail-val">${r.appStatus||'—'}</div></div>
  `;
  document.getElementById('detail-notify-btn').onclick = ()=>{ sendReminderById(id); closeModal('detail-modal'); };
  document.getElementById('detail-modal').classList.add('open');
}

// ---- ANALYTICS ----
function renderAnalytics() {
  const typeCounts = {};
  const wardCounts = {};
  liveData.forEach(r=>{
    const k = shortType(r.type).toUpperCase();
    typeCounts[k] = (typeCounts[k]||0)+1;
    wardCounts[r.ward] = (wardCounts[r.ward]||0)+1;
  });
  const colors = ['#f5a623','#22c55e','#3b82f6','#ef4444','#a855f7','#ec4899','#14b8a6','#f59e0b','#6366f1','#84cc16'];
  function barChart(containerId, data) {
    const el = document.getElementById(containerId);
    if(!el) return;
    const sorted = Object.entries(data).sort((a,b)=>b[1]-a[1]);
    const max = sorted[0][1];
    el.innerHTML = sorted.map(([k,v],i)=>`
      <div class="chart-bar-row">
        <div class="cbl" title="${k}">${truncate(k,18)}</div>
        <div class="cbt"><div class="cbf" style="width:${v/max*100}%;background:${colors[i%colors.length]}"></div></div>
        <div class="cbv">${v}</div>
      </div>`).join('');
  }
  barChart('type-chart', typeCounts);
  barChart('ward-chart', wardCounts);
}

// ---- SEARCH ----
function handleSearch(val) {
  allSearch = val;
  allPage = 1;
  if(document.getElementById('section-licenses').classList.contains('active')) {
    renderAll();
  } else {
    // search on dash
    if(!val) { renderDash(); return; }
    const q = val.toLowerCase();
    const list = liveData.filter(r=>
      r.client.toLowerCase().includes(q)||
      r.licNo.toLowerCase().includes(q)||
      (r.business||'').toLowerCase().includes(q)||
      r.ward.toLowerCase().includes(q)
    ).slice(0,12);
    const tbody = document.getElementById('dash-tbody');
    tbody.innerHTML = list.length ? list.map(r=>`
      <tr onclick="viewDetail(${r.id})">
        <td><div class="td-name">${truncate(r.client,22)}</div><div class="td-sub">${r.ward}</div></td>
        <td style="font-family:var(--font-mono);font-size:11px;color:var(--text3)">${r.licNo}</td>
        <td style="font-size:11px;color:var(--text2)">${truncate(shortType(r.type),25)}</td>
        <td style="font-family:var(--font-mono);font-size:11px">${r.expiry}</td>
        <td>${daysHtml(r.daysLeft)}</td>
        <td>${badgeHtml(r.status)}</td>
        <td><button class="action-btn" onclick="event.stopPropagation();sendReminderById(${r.id})">📨</button></td>
      </tr>`).join('')
    : '<tr><td colspan="7" style="text-align:center;padding:32px;color:var(--text3)">No results found</td></tr>';
  }
}

// ---- ACTIONS ----
function sendReminderById(id) {
  const r = liveData.find(x=>x.id===id);
  if(!r) return;
  showToast(`📨 Reminder queued for ${r.client} (${r.licNo})`, 'success');
  notifications.unshift({id:'m'+Date.now(), type:'b', title:'Manual Reminder Sent', msg:`${r.client} — ${r.licNo} (${r.ward})`, time:'Just now', unread:true});
  renderNotif('notif-list');
}
function sendBulkReminder() {
  const count = liveData.filter(r=>r.status==='expiring').length;
  showToast(`📨 Reminders sent to all ${count} expiring licence holders.`, 'success');
}
function filterDash(f,el) {
  document.querySelectorAll('.card-actions .btn-sm').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderDash(f);
}
function toggleSwitch(el,name) {
  el.classList.toggle('on');
  showToast(`${name.charAt(0).toUpperCase()+name.slice(1)} ${el.classList.contains('on')?'enabled':'disabled'}.`, el.classList.contains('on')?'success':'warning');
}
function exportCSV() {
  const headers = ['Applicant Name','Trade Name','Ward','Type','Licence No.','Registration For','Validity/Payment For','Expiry','Days Left','Status','Fee Paid','Application Status'];
  const rows = liveData.map(r=>[r.client,r.business,r.ward,r.type,r.licNo,r.regFor,r.validFor,r.expiry,r.daysLeft,r.status,r.feePaid,r.appStatus].map(v=>`"${String(v).replace(/"/g,'""')}"`));
  const csv = [headers,...rows].map(r=>r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = 'zone6_licences.csv';
  a.click();
  showToast('CSV exported — zone6_licences.csv', 'success');
}
function addLicence() {
  const name=document.getElementById('f-name').value.trim();
  const trade=document.getElementById('f-trade').value.trim();
  const ward=document.getElementById('f-ward').value;
  const type=document.getElementById('f-type').value;
  const expiry=document.getElementById('f-expiry').value;
  if(!name||!trade||!ward||!type||!expiry){showToast('Please fill all required fields.','error');return;}
  const [y,m,d]=expiry.split('-');
  const expStr=`${d.padStart(2,'0')}-${m.padStart(2,'0')}-${y}`;
  const dl=daysLeft(expStr);
  const newRec={
    id:liveData.length+1,
    licNo:'LC-NEW-'+String(Date.now()).slice(-6),
    client:name, fatherName:document.getElementById('f-father').value,
    business:trade, address:document.getElementById('f-address').value,
    ward, type, mode:document.getElementById('f-mode').value,
    expiry:expStr, regFor:'',validFor:'',
    ackDate:'', signingDate:'', paymentDate:'',
    amount:document.getElementById('f-fee').value, feePaid:document.getElementById('f-fee').value,
    appStatus:'Licence Certificate Generated.',
    status:statusOf(expStr), daysLeft:dl
  };
  liveData.unshift(newRec);
  notifications.unshift({id:'n'+Date.now(),type:'g',title:'New Licence Added',msg:`${name} — ${trade} (${ward})`,time:'Just now',unread:true});
  closeModal('add-modal');
  renderDash();renderNotif('notif-list');
  showToast(`Licence added for ${name}`, 'success');
}

// ---- MODAL ----
function openAddModal() { document.getElementById('add-modal').classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(el=>el.addEventListener('click',e=>{if(e.target===e.currentTarget)el.classList.remove('open')}));

// ---- TOAST ----
function showToast(msg,type='success') {
  const c=document.getElementById('toast-container');
  const t=document.createElement('div');
  t.className=`toast ${type}`;
  t.innerHTML=`<span>${{success:'✅',warning:'⚠️',error:'❌'}[type]||'ℹ️'}</span><span>${msg}</span>`;
  c.appendChild(t);
  setTimeout(()=>t.remove(),4000);
}

// ---- NAVIGATION ----
const titles = {
  dashboard:'Dashboard <span>Zone-6 Overview</span>',
  licenses:'All Licences <span>Zone-6 Records</span>',
  expiring:'Expiring Soon <span>Action Required</span>',
  expired:'Expired Licences <span>Renewal Required</span>',
  notifications:'Notification Log <span>Automated Alerts</span>',
  scheduler:'Scheduler <span>Task Automation</span>',
  analytics:'Analytics <span>Zone-6 Insights</span>',
  settings:'Settings <span>Configuration</span>',
};
function navigate(s, el) {
  document.querySelectorAll('.section').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(x=>x.classList.remove('active'));
  document.getElementById('section-'+s).classList.add('active');
  if(el)el.classList.add('active');
  document.getElementById('topbar-title').innerHTML=titles[s]||s;
  if(s==='licenses')renderAll();
  if(s==='expiring')renderExpiring();
  if(s==='expired')renderExpired();
  if(s==='notifications')renderNotif('full-notif-list');
  if(s==='analytics')setTimeout(renderAnalytics,80);
  document.getElementById('sidebar').classList.remove('open');
}
function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }

// ---- INIT ----
renderDash();
renderNotif('notif-list');
</script>
